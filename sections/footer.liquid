<footer class="site-footer" role="contentinfo">
  <div class="container">
    <nav aria-label="{{ 'a11y.footer_nav' | t: default: 'Навігація у футері' }}">
      <a href="{{ routes.account_login_url }}">{{ 'footer.login' | t: default: 'Вхід' }}</a>
      <a href="{{ routes.search_url }}">{{ 'footer.search' | t: default: 'Пошук' }}</a>
    </nav>
    <small
      >&copy; {{ 'footer.copyright' | t: default: 'Всі права захищені' }}
      {{ shop.name | escape -}}
    </small>
  </div>
</footer>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding }}px;
    padding-bottom: {{ section.settings.padding }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mobile_padding }}px;
      padding-bottom: {{ section.settings.mobile_padding }}px;
    }
  }
{%- endstyle -%}

{%- assign img_w = 600 -%}

{% for block in section.blocks %}
  {% case block.settings.aspect_ratio %}
    {% when '16 / 9' %}
      {%- assign img_h = img_w | times: 9 | divided_by: 16 -%}
    {% when '1 / 1' %}
      {%- assign img_h = img_w -%}
    {% when '3 / 2' %}
      {%- assign img_h = img_w | times: 2 | divided_by: 3 -%}
    {% else %}
      {%- assign img_h = img_w | times: 9 | divided_by: 16 -%}
  {% endcase %}

  <div class="promo-banner" style="aspect-ratio: {{ block.settings.aspect_ratio }};">
    {% if block.settings.image != blank %}
      <img
        src="{{ block.settings.image | image_url: width: img_w, height: img_h }}"
        width="{{ img_w }}"
        height="{{ img_h }}"
        loading="lazy"
        decoding="async"
        alt="{{ block.settings.title | escape | default: shop.name }}"
      >
    {% else %}
      <img
        src="{{ 'placeholder.svg' | asset_url }}"
        width="{{ img_w }}"
        height="{{ img_h }}"
        loading="lazy"
        decoding="async"
        alt="Placeholder"
      >
    {% endif %}

    <div class="promo-content">
      <h3>{{ block.settings.title }}</h3>
      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="btn">{{ block.settings.button_text }}</a>
      {% endif %}
    </div>
  </div>
{% endfor %}

{% schema %}
{
  "name": "Promo Banners",
  "settings": [
    { "type": "text", "id": "title", "label": "Заголовок" },
    { "type": "richtext", "id": "subtitle", "label": "Підзаголовок" },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Вирівнювання тексту",
      "options": [
        { "value": "left", "label": "Зліва" },
        { "value": "center", "label": "По центру" },
        { "value": "right", "label": "Справа" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Відступи секції",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Відступи секції на мобільних пристроях",
      "default": 32
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Кольорова схема",
      "options": [
        { "value": "light", "label": "Світла" },
        { "value": "dark", "label": "Темна" },
        { "value": "accent", "label": "Акцентна" }
      ],
      "default": "light"
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Зображення" },
        { "type": "text", "id": "title", "label": "Заголовок" },
        { "type": "text", "id": "button_text", "label": "Текст кнопки" },
        { "type": "url", "id": "button_link", "label": "Посилання" },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Співвідношення сторін",
          "options": [
            { "value": "16 / 9", "label": "16:9" },
            { "value": "1 / 1", "label": "1:1" },
            { "value": "3 / 2", "label": "3:2" }
          ],
          "default": "16 / 9"
        }
      ]
    }
  ],
  "presets": [{ "name": "Promo Banners" }]
}
{% endschema %}

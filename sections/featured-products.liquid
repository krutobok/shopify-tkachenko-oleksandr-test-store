{{ 'featured-products.css' | asset_url | stylesheet_tag }}

<section id="featured-products-{{ section.id }}" class="featured-products-section section-{{ section.id }}">
  {%- assign collection_handle = section.settings.collection -%}
  {%- assign collection = collections[collection_handle] -%}

  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="featured-products__title">{{ section.settings.title }}</h2>
    {% endif %}

    {% if collection and collection.products_count > 0 %}
      <div class="featured-products__controls">
        <label for="sort-{{ section.id }}">Сортувати:</label>
        {%- assign current_sort = request.params.sort_by | default: 'best-selling' -%}
        <select id="sort-{{ section.id }}" class="featured-products__sort" data-section-id="{{ section.id }}">
          <option
            value="best-selling"
            {% if current_sort == 'best-selling' %}
              selected
            {% endif %}
          >
            Найпопулярніші
          </option>
          <option
            value="price-ascending"
            {% if current_sort == 'price-ascending' %}
              selected
            {% endif %}
          >
            Ціна: від дешевших
          </option>
          <option
            value="price-descending"
            {% if current_sort == 'price-descending' %}
              selected
            {% endif %}
          >
            Ціна: від дорожчих
          </option>
          <option
            value="title-ascending"
            {% if current_sort == 'title-ascending' %}
              selected
            {% endif %}
          >
            Назва: A–Z
          </option>
        </select>
      </div>

      {%- assign sort_by = request.params.sort_by | default: 'best-selling' -%}

      {% case sort_by %}
        {% when 'price-ascending' %}
          {% assign sorted_products = collection.products | sort: 'price' %}
        {% when 'price-descending' %}
          {% assign sorted_products = collection.products | sort: 'price' | reverse %}
        {% when 'title-ascending' %}
          {% assign sorted_products = collection.products | sort: 'title' %}
        {% else %}
          {% assign sorted_products = collection.products %}
      {% endcase %}

      <div class="featured-products__grid">
        {% for product in sorted_products limit: section.settings.products_count %}
          <div class="featured-product">
            <a href="{{ product.url }}" class="featured-product__image">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 300, height: 300 }}"
                  width="300"
                  height="300"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                >
              {% else %}
                <img
                  src="{{ 'placeholder.svg' | asset_url }}"
                  width="300"
                  height="300"
                  alt="Placeholder"
                  loading="lazy"
                >
              {% endif %}
            </a>

            <h3 class="featured-product__title">{{ product.title }}</h3>

            {% if section.settings.show_price %}
              <p class="featured-product__price">{{ product.price | money }}</p>
            {% endif %}

            {% if section.settings.show_rating %}
              {% if product.metafields.reviews.rating.value %}
                <div class="featured-product__rating">⭐ {{ product.metafields.reviews.rating.value }} / 5</div>
              {% else %}
                <div class="featured-product__rating">⭐⭐⭐⭐☆ <span>(4.5/5)</span></div>
              {% endif %}
            {% endif %}

            {% if section.settings.show_add_to_cart %}
              <button
                class="btn add-to-cart btn-dark"
                data-product-id="{{ product.variants.first.id }}"
                data-section-id="{{ section.id }}"
              >
                Додати в кошик
              </button>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p>Будь ласка, виберіть колекцію в налаштуваннях секції або додайте товари.</p>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sortMap = {
      'best-selling': 'best-selling',
      'price-low': 'price-ascending',
      'price-high': 'price-descending',
      'title-ascending': 'title-ascending',
    };

    document.querySelectorAll('.featured-products__sort').forEach((select) => {
      select.addEventListener('change', async (e) => {
        const sectionId = e.target.dataset.sectionId;
        let sortBy = e.target.value;
        const url = `${window.location.pathname}?section_id=${sectionId}&sort_by=${encodeURIComponent(sortBy)}`;
        console.log(url);
        try {
          const res = await fetch(url);
          if (!res.ok) throw new Error('Network error');
          const text = await res.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(text, 'text/html');
          const newSection = doc.querySelector(`#featured-products-${sectionId}`);
          const oldSection = document.querySelector(`#featured-products-${sectionId}`);
          if (newSection && oldSection) {
            oldSection.innerHTML = newSection.innerHTML;
          }
        } catch (error) {
          console.error('Помилка при оновленні секції:', error);
        }
      });
    });

    document.addEventListener('click', async (e) => {
      if (e.target.classList.contains('add-to-cart')) {
        e.preventDefault();
        const variantId = e.target.dataset.productId;
        const body = JSON.stringify({ items: [{ id: variantId, quantity: 1 }] });

        try {
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
          });

          if (res.ok) {
            try {
              const cartRes = await fetch('/?sections=cart-icon-bubble');
              const html = await cartRes.text();
              const parser = new DOMParser();
              const doc = parser.parseFromString(html, 'text/html');
              const newCart = doc.querySelector('#cart-icon-bubble');
              const oldCart = document.querySelector('#cart-icon-bubble');
              if (oldCart && newCart) oldCart.innerHTML = newCart.innerHTML;
            } catch (err) {
              console.warn('Не вдалося оновити міні-кошик', err);
            }
          } else {
            console.error('Помилка при додаванні товару', await res.text());
          }
        } catch (error) {
          console.error('Fetch error:', error);
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "title", "label": "Заголовок" },
    { "type": "collection", "id": "collection", "label": "Вибір колекції" },
    {
      "type": "range",
      "id": "products_count",
      "label": "Кількість товарів",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    { "type": "checkbox", "id": "show_price", "label": "Показувати ціну", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "Показувати рейтинг", "default": false },
    { "type": "checkbox", "id": "show_add_to_cart", "label": "Кнопка «Додати в кошик»", "default": true }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}

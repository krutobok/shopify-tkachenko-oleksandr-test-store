{{ 'designers.css' | asset_url | stylesheet_tag }}

<section class="designers">
  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="designers__title">{{ section.settings.title }}</h2>
    {% endif %}

    {% assign featured_collection = collections[section.settings.featured_collection] %}
    {% assign designers = featured_collection.metafields.custom.designer.value %}
    {% assign designers_count = 0 %}
    {% for designer in designers %}
      {%- assign designers_count = designers_count | plus: 1 -%}
    {% endfor %}

    <div class="designers__grid">
      {% for designer in designers %}
        <div class="designer-card">
          {% if designer.photo.value != blank %}
            {% comment %}
              <img
                src="{{ designer.photo.value | image_url: width: 300 }}"
                alt="{{ designer.photo.value.alt | default: designer.name | escape }}"
                class="designer-photo"
                loading="lazy"
                width="300"
                height="300"
              >
            {% endcomment %}
            {%- assign image_alt = designer.photo.value.alt | default: designer.name | escape -%}

            {{
              designer.photo.value
              | image_url: width: 1400, height: 1000
              | image_tag:
                class: 'designer-photo',
                alt: image_alt,
                widths: '300, 450, 600, 700, 900, 1200, 1400',
                sizes: '(min-width: 1400px) 420px, (min-width: 1024px) calc((100vw - 130px) / 3), (min-width: 767px) calc((100vw - 100px) / 2), calc(100vw - 65px)',
                loading: 'lazy'
            }}
          {% endif %}

          <h3 class="designer-name">{{ designer.name }}</h3>
          <p class="designer-role">{{ designer.role }}</p>
          <p class="designer-bio">{{ designer.bio }}</p>

          <div class="designer-tags">
            {% for tag in designer.tags.value %}
              <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>

          <div class="designer-links">
            {% for link in designer.portfolio_links.value %}
              <a href="{{ link }}" target="_blank">{{ link }}</a>
            {% endfor %}
          </div>

          <p class="designer-date">Born: {{ designer.birth_date | date: '%B %d, %Y' }}</p>

          {% if designer.verified %}
            <span class="verified">✅ Verified Designer</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Designers Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Заголовок секції",
      "default": "Our Designers"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Виберіть колекцію дизайнерів"
    }
  ],
  "presets": [{ "name": "Designers" }]
}
{% endschema %}

{{ 'banner-product.css' | asset_url | stylesheet_tag }}

{% if section.settings.product != blank %}
  {% assign current_product = all_products[section.settings.product] %}
{% elsif section.settings.handle != blank %}
  {% assign current_product = all_products[section.settings.handle] %}
{% endif %}

<section class="product section">
  <div class="container">
    {%- if current_product == blank -%}
      <p>Product not found</p>
    {%- else -%}
      <div class="product__wrapper">
        {%- assign color_index = -1 -%}
        {%- for option in current_product.options -%}
          {%- assign opt_down = option | downcase -%}
          {%- if opt_down contains 'color'
            or opt_down contains 'colour'
            or opt_down contains 'цвет'
            or opt_down contains 'колір'
          -%}
            {%- assign color_index = forloop.index0 -%}
          {%- endif -%}
        {%- endfor -%}

        <div class="product__gallery">
          {% for variant in current_product.variants %}
            {% assign color_value = variant.options[color_index] | handleize %}
            <div class="product__thumbnails-set {% if forloop.first %}active{% endif %}" data-color="{{ color_value }}">
              {% assign count = 0 %}
              {% for image in current_product.images %}
                {% assign img_name = image.src | split: '/' | last | split: '.' | first | downcase %}
                {% if img_name contains color_value %}
                  {% assign count = count | plus: 1 %}
                  {% if count <= 5 %}
                    <button
                      class="product__thumb {% if count == 1 %}product__thumb--active{% endif %}"
                      aria-label="Change main product photo to {{ color_value }} photo {{ count }}"
                      aria-selected="{% if count == 1 %}true{% else %}false{% endif %}"
                      data-image="{{ image | image_url: width: 536 }}"
                    >
                      <img
                        class="product__thumb-img product__img--mini"
                        width="88"
                        height="88"
                        src="{{ image | image_url: width: 88, height: 88 }}"
                        alt="{{ image.alt | default: current_product.title | default: 'Product photo' }}"
                      >
                    </button>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          {% endfor %}

          <div class="product__main">
            {% render 'product-badge', product: current_product %}
            {%- if current_product.featured_image -%}
              <img
                class="product__image"
                src="{{ current_product.featured_image | image_url: width: 536, height: 536 }}"
                width="536"
                height="536"
                alt="{{ current_product.featured_image.alt | default: current_product.title | default: 'Фото товару' }}"
              >
            {%- else -%}
              <img
                class="product__image"
                width="536"
                height="536"
                src="{{ 'placeholder.svg' | image_url: width: 536, height: 536 }}"
                alt="{{ current_product.title | default: 'Фото товару' }}"
              >
            {%- endif -%}
          </div>
        </div>

        <div class="product__info">
          <div class="product__text-inner">
            <h2 class="product__title title-small">{{ current_product.title | escape }}</h2>
            {% if current_product.price != blank %}
              {% render 'product-price', product: current_product %}
            {% endif %}
          </div>

          {%- if color_index != -1 -%}
            <div
              class="product__colors"
            >
              {{ 'product.banner.select_color' | t: default: 'Оберіть колір' }}
              {% render 'product-colors', product: current_product, color_index: color_index %}
            </div>
          {%- else -%}
            <p>No color option found for this product.</p>
          {%- endif -%}

          <div class="product__size-inner">
            <p class="product__size-text text-medium">Select Size:</p>
            <div class="product__sizes">
              <button class="product__size product__size--active btn">UK 5.5</button>
              <button class="product__size btn">UK 6 (EU 39)</button>
              <button class="product__size btn">UK 6 (EU 40)</button>
              <button class="product__size btn">UK 6.5</button>
              <button class="product__size btn">UK 7</button>
              <button class="product__size btn">UK 7.5</button>
            </div>
          </div>

          <a
            id="add-to-cart-link"
            href="{{routes.cart_add_url}}?id={{ current_product.selected_or_first_available_variant.id }}&quantity=1"
            class="product__btn btn btn-dark"
          >
            Add To Bag
          </a>

          <p class="product__desc text-medium">
            {{- current_product.description | default: 'Для цього товару відсутній опис' | escape -}}
          </p>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>
<script>
  const colorButtons = document.querySelectorAll('.product__color');
  const thumbs = document.querySelectorAll('.product__thumb');
  const thumbnailSets = document.querySelectorAll('.product__thumbnails-set');
  const mainImage = document.querySelector('.product__image');
  const priceWrapper = document.querySelector('.product__price');
  const addToCartLink = document.getElementById('add-to-cart-link');

  colorButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selectedColor = btn.dataset.color.toLowerCase().replace(/\s+/g, '-');

      colorButtons.forEach((c) => c.classList.remove('product__color--active'));
      btn.classList.add('product__color--active');
      thumbnailSets.forEach((set) => set.classList.remove('active'));

      const activeSet = document.querySelector(`.product__thumbnails-set[data-color="${selectedColor}"]`);
      if (activeSet) {
        activeSet.classList.add('active');

        const firstThumb = activeSet.querySelector('.product__thumb');
        if (firstThumb) {
          mainImage.src = firstThumb.dataset.image;
        }
      }
      const variantId = btn.dataset.variantId;
      if (variantId) {
        addToCartLink.href = `/cart/add?id=${variantId}&quantity=1`;
      }
      const price = btn.dataset.price;
      const comparePrice = btn.dataset.comparePrice;
      if (
        comparePrice &&
        parseFloat(comparePrice.replace(/[^0-9.]/g, '')) > parseFloat(price.replace(/[^0-9.]/g, ''))
      ) {
        priceWrapper.innerHTML = `
        <span class="price-sale">${price}</span>
        <span class="price-old">${comparePrice}</span>
      `;
      } else {
        priceWrapper.innerHTML = `
        <span class="price">${price}</span>
      `;
      }
      alert(btn.dataset.message);
    });
  });
  thumbs.forEach((btn) => {
    btn.addEventListener('click', () => {
      const newImage = btn.dataset.image;
      mainImage.src = newImage;

      thumbs.forEach((t) => {
        t.classList.remove('product__thumb--active');
        t.setAttribute('aria-selected', 'false');
      });

      btn.classList.add('product__thumb--active');
      btn.setAttribute('aria-selected', 'true');
    });
  });
</script>

<div class="absolute flex gap-4 left-4 top-4 rounded-sm bg-primary-bg p-2 text-medium">
  {% assign vendor_down = product.vendor | downcase %}
  {% case vendor_down %}
    {% when 'nike' %}
      <span class="text-primary">🔥 Top Seller</span>
    {% when 'adidas' %}
      <span class="text-primary">⭐ Premium</span>
    {% when 'puma' %}
      <span class="text-primary">💎 Exclusive</span>
    {% else %}
      <span class="text-primary">🆕 New</span>
  {% endcase %}
</div>
